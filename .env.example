# Copy this file to `.env` and fill in real values.
# .env is gitignored — never commit real keys.

# Anthropic API key. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# HMAC secret used to sign the client-carried context blob.
# Any long random string. Regenerate to invalidate all outstanding contexts.
NATRUN_SECRET=change-me-to-a-long-random-string

# Optional: which system prompt to load from examples/. Defaults to "default".
# NATRUN_SITE=default

# Optional: bind address. Defaults to :8000.
# NATRUN_ADDR=:8000

# Optional: model + max output tokens for the FIRST turn of a session
# (when no history exists yet). A stronger model here establishes the
# visual identity of the site. Defaults: claude-opus-4-7 / 8192.
# NATRUN_MODEL_FIRST=claude-opus-4-7
# NATRUN_MAX_TOK_FIRST=8192

# Optional: model + max output tokens for every CONSECUTIVE turn.
# A cheaper/faster model is usually fine once the look is set.
# Defaults: claude-haiku-4-5 / 8192.
# NATRUN_MODEL_NEXT=claude-haiku-4-5
# NATRUN_MAX_TOK_NEXT=8192
